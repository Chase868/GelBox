<?xml version="1.0" encoding="utf-8"?>

<views:BasePage
    x:Class="GelBox.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:GelBox.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <!-- Login Form -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="560"
                        Margin="48,48,48,48">

                <!-- Logo -->
                <Image Source="ms-appx:///Assets/Square150x150Logo.png" Width="100" Height="100"
                       Margin="0,0,0,16" />

                <!-- Header -->
                <TextBlock Text="Sign In"
                           Style="{StaticResource TitleTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32" />

                <!-- Login Card -->
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="{StaticResource LargeCornerRadius}"
                        Padding="28,24">
                    <StackPanel>
                        <TextBlock Text="Username"
                                   FontSize="13"
                                   Foreground="#80FFFFFF"
                                   Margin="0,0,0,6" />
                        <TextBox x:Name="UsernameTextBox"
                                 Text="{x:Bind ViewModel.Username, Mode=TwoWay}"
                                 Background="#222222"
                                 BorderBrush="#333333"
                                 CornerRadius="{StaticResource SmallCornerRadius}"
                                 Padding="12,10"
                                 TabIndex="1" />

                        <TextBlock Text="Password"
                                   FontSize="13"
                                   Foreground="#80FFFFFF"
                                   Margin="0,18,0,6" />
                        <PasswordBox x:Name="PasswordBox"
                                     Password="{x:Bind ViewModel.Password, Mode=TwoWay}"
                                     Background="#222222"
                                     BorderBrush="#333333"
                                     CornerRadius="{StaticResource SmallCornerRadius}"
                                     Padding="12,10"
                                     TabIndex="2" />

                        <Button Content="Sign In"
                                Command="{x:Bind ViewModel.LoginCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Height="48"
                                FontSize="16"
                                FontWeight="SemiBold"
                                CornerRadius="{StaticResource MediumCornerRadius}"
                                Margin="0,24,0,0"
                                TabIndex="3" />

                        <!-- Divider -->
                        <Grid Margin="0,20,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Height="1" Fill="#20FFFFFF" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="OR" Foreground="#50FFFFFF" FontSize="12"
                                       Margin="12,0" />
                            <Rectangle Grid.Column="2" Height="1" Fill="#20FFFFFF" VerticalAlignment="Center" />
                        </Grid>

                        <Button Content="Quick Connect"
                                Command="{x:Bind ViewModel.QuickConnectCommand}"
                                IsEnabled="{x:Bind ViewModel.IsQuickConnectEnabled, Mode=OneWay}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Height="48"
                                FontSize="15"
                                CornerRadius="{StaticResource MediumCornerRadius}"
                                TabIndex="4" />
                    </StackPanel>
                </Border>

                <ProgressRing IsActive="{x:Bind ViewModel.IsLoadingRingActive, Mode=OneWay}"
                              Width="48"
                              Height="48"
                              Margin="0,20,0,0" />

                <TextBlock Text="{x:Bind ViewModel.ErrorText, Mode=OneWay}"
                           Foreground="#FF6B6B"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Style="{StaticResource StandardCaptionTextStyle}"
                           Margin="0,12,0,0"
                           Visibility="{x:Bind ViewModel.IsErrorVisible, Mode=OneWay}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</views:BasePage>
