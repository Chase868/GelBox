<?xml version="1.0" encoding="utf-8"?>

<views:BasePage
    x:Class="GelBox.Views.ServerSelectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:GelBox.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <!-- Main content -->
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="560">

            <!-- Header -->
            <Image Source="ms-appx:///Assets/Square150x150Logo.png" Width="120" Height="120"
                   Margin="0,0,0,16" />
            <TextBlock Text="Welcome"
                       Style="{StaticResource TitleTextStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6" />
            <TextBlock Text="Connect to your Jellyfin server to get started"
                       Style="{StaticResource StandardBodyTextStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,28"
                       Foreground="#B3FFFFFF"
                       TextAlignment="Center" />

            <!-- Server URL Card -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="{StaticResource LargeCornerRadius}"
                    Padding="24,20"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Server URL"
                               FontSize="13"
                               Foreground="#80FFFFFF"
                               Margin="0,0,0,8" />
                    <TextBox x:Name="ServerUrlTextBox"
                             Text="{x:Bind ViewModel.ServerUrl, Mode=TwoWay}"
                             PlaceholderText="http://server:8096"
                             IsTabStop="True"
                             TabIndex="1"
                             InputScope="Url"
                             Foreground="White"
                             Background="#222222"
                             BorderBrush="#333333"
                             CornerRadius="{StaticResource SmallCornerRadius}"
                             PlaceholderForeground="#666666"
                             Padding="12,10" />

                    <!-- SSL Certificate Options -->
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Allow Untrusted Certificates"
                                   FontSize="14"
                                   Foreground="#B3FFFFFF"
                                   VerticalAlignment="Center" />
                        <ToggleSwitch Grid.Column="1"
                                      IsOn="{x:Bind ViewModel.AllowUntrustedCertificates, Mode=TwoWay}"
                                      IsTabStop="True"
                                      TabIndex="2"
                                      MinWidth="0" />
                    </Grid>
                </StackPanel>
            </Border>

            <Button Content="Connect"
                    Command="{x:Bind ViewModel.ConnectCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Height="48"
                    FontSize="16"
                    FontWeight="SemiBold"
                    CornerRadius="{StaticResource MediumCornerRadius}"
                    Margin="0,4,0,0"
                    IsTabStop="True"
                    TabIndex="3" />

        </StackPanel>

        <!-- Loading overlay -->
        <Grid Background="#E6080808"
              Visibility="{x:Bind ViewModel.IsLoadingOverlayVisible, Mode=OneWay}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoadingRingActive, Mode=OneWay}"
                              Width="48"
                              Height="48" />
                <TextBlock Text="{x:Bind ViewModel.LoadingText, Mode=OneWay}"
                           Style="{StaticResource StandardBodyTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"
                           Foreground="#B3FFFFFF" />
            </StackPanel>
        </Grid>
    </Grid>
</views:BasePage>
